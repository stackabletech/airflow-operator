---
apiVersion: v1
kind: ConfigMap
metadata:
  name: openlineage-receiver-script
data:
  receiver.py: |
    #!/usr/bin/env python
    # Minimal OpenLineage receiver used for integration testing.
    # POST /api/v1/lineage appends the request body to a log; GET /events returns
    # everything received so far (so the test can assert lineage was emitted).
    import http.server
    import os
    import ssl

    TOKEN = os.environ.get("EXPECTED_TOKEN")
    EVENTS = "/tmp/events.log"
    PORT = int(os.environ.get("PORT", "5000"))
    USE_TLS = os.environ.get("USE_TLS") == "true"

    class Handler(http.server.BaseHTTPRequestHandler):
        def do_POST(self):
            if TOKEN:
                if self.headers.get("Authorization", "") != f"Bearer {TOKEN}":
                    self.send_response(401)
                    self.end_headers()
                    return
            length = int(self.headers.get("Content-Length", 0))
            body = self.rfile.read(length) if length else b""
            with open(EVENTS, "ab") as f:
                f.write(body + b"\n")
            self.send_response(201)
            self.end_headers()

        def do_GET(self):
            try:
                with open(EVENTS, "rb") as f:
                    data = f.read()
            except FileNotFoundError:
                data = b""
            self.send_response(200)
            self.end_headers()
            self.wfile.write(data)

        def log_message(self, *args):
            pass

    httpd = http.server.HTTPServer(("0.0.0.0", PORT), Handler)
    if USE_TLS:
        ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
        ctx.load_cert_chain("/tls/tls.crt", "/tls/tls.key")
        httpd.socket = ctx.wrap_socket(httpd.socket, server_side=True)
    httpd.serve_forever()
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: openlineage-receiver
spec:
  replicas: 1
  selector:
    matchLabels:
      app: openlineage-receiver
  template:
    metadata:
      labels:
        app: openlineage-receiver
    spec:
      serviceAccountName: integration-tests-sa
      # fsGroup makes the secret-operator-provisioned TLS key readable by the (non-root) receiver
      # process. Mirrors the OpenLDAP integration-test receiver.
      securityContext:
        runAsUser: 1000
        runAsGroup: 1000
        fsGroup: 1000
      containers:
        - name: receiver
          image: oci.stackable.tech/sdp/testing-tools:0.3.0-stackable0.0.0-dev
          command: ["python", "/scripts/receiver.py"]
          env:
            - name: PORT
              value: "5000"
{% if test_scenario['values']['openlineage-use-tls'] == 'true' %}
            - name: USE_TLS
              value: "true"
{% endif %}
{% if test_scenario['values']['openlineage-use-auth'] == 'true' %}
            - name: EXPECTED_TOKEN
              value: openlineage-test-token
{% endif %}
          ports:
            - containerPort: 5000
          volumeMounts:
            - name: script
              mountPath: /scripts
{% if test_scenario['values']['openlineage-use-tls'] == 'true' %}
            - name: tls
              mountPath: /tls
              readOnly: true
{% endif %}
      volumes:
        - name: script
          configMap:
            name: openlineage-receiver-script
{% if test_scenario['values']['openlineage-use-tls'] == 'true' %}
        # Server certificate issued by the autoTls SecretClass. The `service` scope adds the
        # receiver Service's DNS name (openlineage-receiver.<ns>.svc.cluster.local) as a SAN, so it
        # matches the host the Airflow OpenLineage client connects to.
        - name: tls
          ephemeral:
            volumeClaimTemplate:
              metadata:
                annotations:
                  secrets.stackable.tech/class: openlineage-ca-cert
                  secrets.stackable.tech/scope: service=openlineage-receiver
              spec:
                storageClassName: secrets.stackable.tech
                accessModes:
                  - ReadWriteOnce
                resources:
                  requests:
                    storage: "1"
{% endif %}
---
apiVersion: v1
kind: Service
metadata:
  name: openlineage-receiver
spec:
  selector:
    app: openlineage-receiver
  ports:
    - port: 5000
      targetPort: 5000
