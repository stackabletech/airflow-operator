---
apiVersion: kuttl.dev/v1beta1
kind: TestStep
metadata:
  name: openlineage-secretclass-auth-connection
commands:
  - script: |
      kubectl apply -n "$NAMESPACE" -f - <<EOF
{% if test_scenario['values']['openlineage-use-tls'] == 'true' %}
      ---
      # autoTls SecretClass: issues the receiver's server cert (via a mounted SecretClass volume)
      # and provides the CA the Airflow OpenLineage client verifies against.
      apiVersion: secrets.stackable.tech/v1alpha1
      kind: SecretClass
      metadata:
        name: openlineage-ca-cert
      spec:
        backend:
          autoTls:
            ca:
              autoGenerate: true
              secret:
                name: openlineage-ca-cert-ca
                namespace: $NAMESPACE
{% endif %}
{% if test_scenario['values']['openlineage-use-auth'] == 'true' %}
      ---
      apiVersion: v1
      kind: Secret
      metadata:
        name: openlineage-credentials
      type: Opaque
      stringData:
        # The OpenLineage HTTP transport bearer token must live under the fixed key 'apiKey'.
        apiKey: openlineage-test-token
      ---
      apiVersion: authentication.stackable.tech/v1alpha1
      kind: AuthenticationClass
      metadata:
        name: openlineage-auth
      spec:
        provider:
          static:
            userCredentialsSecret:
              name: openlineage-credentials
{% endif %}
      ---
      apiVersion: openlineage.stackable.tech/v1alpha1
      kind: OpenLineageConnection
      metadata:
        name: openlineage-receiver-connection
      spec:
        host: openlineage-receiver.$NAMESPACE.svc.cluster.local
        port: 5000
{% if test_scenario['values']['openlineage-use-tls'] == 'true' %}
        tls:
          verification:
            server:
              caCert:
                secretClass: openlineage-ca-cert
{% endif %}
{% if test_scenario['values']['openlineage-use-auth'] == 'true' %}
        authenticationClassRef: openlineage-auth
{% endif %}
      EOF
